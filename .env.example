# Copy this file to .env and fill in your values
# cp .env.example .env

PORT=5001

# MongoDB (optional — app runs in-memory without it)
# Local:  mongodb://localhost:27017/healthhub
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/healthhub
MONGO_URI=mongodb://localhost:27017/healthhub

# JWT — change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

NODE_ENV=development
CLIENT_URL=http://localhost:5174
